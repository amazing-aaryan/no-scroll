<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NoScroll Setup"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFAAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1E1E2E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/overlay_step_title"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/overlay_check"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/presence_online"
                    android:visibility="gone"
                    android:contentDescription="Granted" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/overlay_step_desc"
                android:textColor="#FFAAAAAA"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/overlay_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/overlay_btn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF1E1E2E"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/accessibility_step_title"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/accessibility_check"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/presence_online"
                    android:visibility="gone"
                    android:contentDescription="Enabled" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/accessibility_step_desc"
                android:textColor="#FFAAAAAA"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/accessibility_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/accessibility_btn" />
        </LinearLayout>

        <Button
            android:id="@+id/done_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/done_btn"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
