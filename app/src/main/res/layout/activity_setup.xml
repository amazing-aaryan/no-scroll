<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_book"
            android:tint="@color/colorAccent"
            android:contentDescription="@null"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup NoScroll"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="36dp" />

        <!-- Step 1 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="0dp"
            app:strokeColor="#22FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:cardCornerRadius="14dp"
                        app:cardBackgroundColor="@color/colorAccent"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="1"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/overlay_step_title"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/overlay_check"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/presence_online"
                        android:tint="@color/colorAccent"
                        android:visibility="gone"
                        android:contentDescription="Granted" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_step_desc"
                    android:textColor="@color/on_surface_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/overlay_btn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/overlay_btn"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    app:backgroundTint="@color/colorAccent"
                    app:cornerRadius="22dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Step 2 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="0dp"
            app:strokeColor="#22FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:cardCornerRadius="14dp"
                        app:cardBackgroundColor="@color/colorAccent"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="2"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/accessibility_step_title"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/accessibility_check"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/presence_online"
                        android:tint="@color/colorAccent"
                        android:visibility="gone"
                        android:contentDescription="Enabled" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/accessibility_step_desc"
                    android:textColor="@color/on_surface_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/accessibility_btn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/accessibility_btn"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    app:backgroundTint="@color/colorAccent"
                    app:cornerRadius="22dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/done_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/done_btn"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:backgroundTint="@color/colorAccent"
            app:cornerRadius="26dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
