<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#171615">

    <!-- Stacked: top bar | PDF | bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar: solid, 44dp -->
        <FrameLayout
            android:id="@+id/metadata_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="#1B1917">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="4dp">
                <TextView
                    android:id="@+id/book_metadata_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="..."
                    android:textColor="#D0F5F0E8"
                    android:textSize="12sp"
                    android:letterSpacing="0.01" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/metadata_lookup_btn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/metadata_lookup"
                    android:textColor="@color/colorAccent"
                    android:textSize="11sp"
                    android:visibility="gone" />
                <ImageButton
                    android:id="@+id/overflow_menu_btn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="More options"
                    android:src="@drawable/ic_more_vert"
                    android:tint="#D0FFFFFF"
                    android:padding="10dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- PDF renderer fills the space between bars -->
        <FrameLayout
            android:id="@+id/pdf_fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom bar: solid, 52dp -->
        <LinearLayout
            android:id="@+id/reader_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#1B1917"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/change_pdf_fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/change_pdf"
                android:src="@drawable/ic_book"
                app:backgroundTint="#1B1917"
                app:elevation="0dp"
                app:fabSize="mini"
                app:tint="#80FFFFFF" />
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/goto_page_fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/goto_page"
                android:src="@drawable/ic_goto_page"
                app:backgroundTint="#1B1917"
                app:elevation="0dp"
                app:fabSize="mini"
                app:tint="#80FFFFFF" />
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/make_quote_fab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/make_quote"
                android:src="@drawable/ic_check_circle"
                app:backgroundTint="@color/colorAccent"
                app:elevation="0dp"
                app:fabSize="mini"
                app:tint="@color/black" />
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Hidden action IDs — zero-size, Kotlin references only -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:visibility="gone">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/highlights_btn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/highlights"
            android:textColor="@color/white" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/ocr_page_btn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/ocr_page"
            android:textColor="@color/white" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/export_highlights_btn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/export_highlights"
            android:textColor="@color/white" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/zen_mode_btn"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/zen_mode"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- Selection pill: floats above bottom bar when text is selected -->
    <FrameLayout
        android:id="@+id/selection_action_rail"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_selection_pill"
        android:clipToOutline="true"
        android:elevation="16dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_highlight"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/highlight"
                android:textColor="@color/colorAccent"
                android:textSize="13sp" />
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#35FFFFFF" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_annotate"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/annotate"
                android:textColor="#D0F5F0E8"
                android:textSize="13sp" />
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#35FFFFFF" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_quote"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/quote"
                android:textColor="#D0F5F0E8"
                android:textSize="13sp" />
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:background="#35FFFFFF" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_share"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/share"
                android:textColor="#D0F5F0E8"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Zen exit handle (top-right corner, zen mode only) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/zen_exit_handle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:alpha="0.35"
        android:contentDescription="@string/exit_zen_mode"
        android:src="@drawable/ic_check_circle"
        android:visibility="gone"
        app:backgroundTint="#80101015"
        app:fabSize="mini"
        app:tint="#C0F5F0E8" />

</FrameLayout>
