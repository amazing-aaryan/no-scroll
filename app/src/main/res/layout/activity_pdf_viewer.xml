<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#171615">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top nav bar -->
        <FrameLayout
            android:id="@+id/metadata_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1B1917">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <ImageButton
                    android:id="@+id/library_btn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="My Library"
                    android:src="@drawable/ic_book"
                    android:tint="#90FFFFFF"
                    android:padding="12dp" />

                <TextView
                    android:id="@+id/book_metadata_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="..."
                    android:textColor="#D0F5F0E8"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <ImageButton
                    android:id="@+id/zen_btn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/zen_mode"
                    android:src="@drawable/ic_lotus"
                    android:tint="#90FFFFFF"
                    android:padding="12dp" />

                <ImageButton
                    android:id="@+id/overflow_nav_btn"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="More options"
                    android:src="@drawable/ic_more_vert"
                    android:tint="#90FFFFFF"
                    android:padding="12dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- PDF renderer fills remaining space; PageTurnInterceptor intercepts horizontal swipes -->
        <com.noscroll.PageTurnInterceptor
            android:id="@+id/pdf_fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>


</FrameLayout>
