<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pdf_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.noscroll.VerticalSeekBar
        android:id="@+id/page_seekbar"
        android:layout_width="36dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="96dp"
        android:visibility="invisible" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/goto_page_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:src="@drawable/ic_goto_page"
        android:contentDescription="@string/goto_page"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/white" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/change_pdf_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_book"
        android:contentDescription="@string/change_pdf"
        app:backgroundTint="@color/colorPrimary"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
