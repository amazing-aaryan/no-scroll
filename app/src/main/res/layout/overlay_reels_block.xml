<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF171615"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:padding="48dp">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/noscroll_logo_transparent_128"
        android:contentDescription="Open your book"
        android:scaleType="fitCenter"
        android:layout_marginBottom="28dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NoScroll"
        android:textColor="#FBF8F0"
        android:textSize="32sp"
        android:fontFamily="serif"
        android:layout_marginBottom="10dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="your book is waiting."
        android:textColor="#8A8378"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="48dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="tap to open"
        android:textColor="#4A4540"
        android:textSize="11sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.12" />

</LinearLayout>
