<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NoScroll" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">#F7F3EA</item>
    </style>

    <style name="Theme.NoScroll.NoActionBar" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">#F7F3EA</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.NoScroll.PdfViewer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">#FBF8F0</item>
        <item name="colorOnSurface">#171615</item>
        <item name="colorOutline">#DDD5C8</item>
        <item name="android:windowBackground">#F7F3EA</item>
        <item name="android:statusBarColor">#F7F3EA</item>
        <item name="android:navigationBarColor">#F7F3EA</item>
        <item name="materialAlertDialogTheme">@style/Dialog.Paper</item>
    </style>

    <style name="Dialog.Paper" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">#FBF8F0</item>
        <item name="colorOnSurface">#171615</item>
        <item name="android:textColorPrimary">#171615</item>
        <item name="android:textColorSecondary">#66615A</item>
    </style>
</resources>
